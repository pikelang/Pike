#pike __REAL_VERSION__

//! @namespace predef::

//! @module GI
//!
//!   This module provides an interface to GObject Introspection.
//!
//!   You probably want to look at @[repository].

inherit @module@ : GI;

#if constant(@module@.Repository)

//! @module repository
//!
//!   This module provides dynamic lookup of modules provided
//!   via GObject Introspection. Such modules are loaded via
//!   @tt{*.typelib@} description files typically located in
//!   the directory @tt{/usr/lib64/girepository-1.0/@} (or
//!   similar).
//!
//!   Typical such modules include @[GI.repository.Gtk],
//!   @[GI.repository.Gdk] and @[GI.repository.Pango].
//!
//!   Several GI-compatible APIs are documented at
//!   @url{https://www.gtk.org/docs/apis/@}.
//!
//! @note
//!   The indexed modules may optionally be prefixed by
//!   an api version number. Eg @[GI.repository.3.0.Gtk]
//!   (for Gtk 3.0) or @[GI.repository.4.0.Gtk] (for Gtk 4.0).
//!   If no version is specified, the latest version will be
//!   returned unless an older version has already been loaded.
//!
//! @seealso
//!   @[Cairo], @[GDK], @[GTK], @[Pango]

//! @ignore
class DynamicImporter(string|zero|void version) {
//! @endignore

  protected Repository repository = get_default_repository();

  protected mapping(string:mixed) cache = ([]);

  protected mixed `[](string namespace)
  {
    if (cache[namespace]) return cache[namespace];

    if (!version) {
      int colon = search(namespace, ":");
      if (colon > 0) {
        string full_version = namespace[colon+1..];
        namespace = namespace[..colon-1];

        DynamicImporter importer = this;
        foreach(full_version/".", string ver) {
          importer = importer[ver];
        }
        return importer[namespace];
      }
    }

    string ver = "";
    sscanf(namespace, "%[0-9]%s", ver, namespace);
    if (sizeof(ver)) {
      // Eg GI.repository.4.0.Gtk
      if (sizeof(namespace)) {
        // Syntax error.
        return UNDEFINED;
      }
      string full_version = ver;
      if (version) {
        full_version = version + "." + ver;
      }
      return cache[ver] = DynamicImporter(full_version);
    }

    if (!repository->enumerate_versions(namespace))
      return UNDEFINED;

    object m = repository->namespace(namespace, version);
    if (m)
      cache[namespace] = m;
    return m;
  }

  protected array(string) _indices() { return indices(cache); }
  protected array(mixed) _values() { return values(cache); }
//! @ignore
}

DynamicImporter repository = DynamicImporter();
//! @endignore

//! @endmodule

#endif

//! @endmodule

//! @endnamespace
