AC_INIT(gi.cmod)
AC_CONFIG_HEADER(gimod_config.h)

AC_ARG_WITH(gi,[  --with(out)-gi        Support GObject introspection via libgirepository (GI)],[],[with_gi=yes])

AC_MODULE_INIT()

PIKE_FEATURE_WITHOUT(GI)

AC_SUBST(GI_CFLAGS)
AC_SUBST(GI_LIBS)

if test x$with_gi = xyes ; then
  PIKE_FEATURE_NODEP(GI)

  MY_AC_PATH_PROG(PKG_CONFIG, ${ac_tool_prefix}pkg-config, no)
  if ${ac_tool_prefix}pkg-config girepository-2.0 2>/dev/null && \
     echo "GI-2.0 not supported yet. Trying GI-1.0..." && false; then
    GI_CFLAGS="`${ac_tool_prefix}pkg-config girepository-2.0 --cflags`"
    GI_LIBS="`${ac_tool_prefix}pkg-config girepository-2.0 --libs`"
    gi_lib="2.0"
  else
    if ${ac_tool_prefix}pkg-config gobject-introspection-1.0 2>/dev/null ; then
      GI_CFLAGS="`${ac_tool_prefix}pkg-config gobject-introspection-1.0 --cflags`"
      GI_LIBS="`${ac_tool_prefix}pkg-config gobject-introspection-1.0 --libs`"
      gi_lib="1.0"
    else
      AC_CHECK_LIB(girepository-1.0, g_irepository_get_default, [
                     GI_LIBS=-lgirepository-1.0
                     gi_lib="1.0"
                   ])
    fi
  fi

  OLDCPPFLAGS="$CPPFLAGS"
  OLDLIBS="$LIBS"
  CPPFLAGS="$GI_CFLAGS $CPPFLAGS"
  LIBS="$GI_LIBS $LIBS"

  case "$gi_lib" in
    2.*)
      AC_CHECK_HEADERS(girepository/girepository.h)
      gi_header_ok="$ac_cv_header_girepository_girepository_h"
      AC_CHECK_FUNC(gi_repository_new, [gi_lib_ok=yes])

      if test xyesyes = "x$gi_header_ok$gi_lib_ok" ; then
          AC_CHECK_HEADERS(girepository/girffi.h,,,[
#include <girepository/girepository.h>
                           ])
        AC_CHECK_FUNCS(gi_callable_info_create_closure gi_constant_info_free_value
                       gi_object_info_find_signal gi_interface_info_find_signal
                       g_value_get_schar g_value_set_schar)
        AC_CHECK_DECLS([GI_TYPE_TAG_UNICHAR],
                       [], [], [[#include <girepository/girepository.h>]])
        AC_DEFINE(HAVE_GI, 2, [Define to major version of GI if available and to be built])
        PIKE_FEATURE_OK(GI, 2.0)
      else
        GI_CFLAGS=""
        GI_LIBS=""
        CPPFLAGS="$OLDCPPFLAGS"
        LIBS="$OLDLIBS"
      fi
    ;;
    1.*)
      AC_CHECK_HEADERS(girepository.h)
      gi_header_ok="$ac_cv_header_girepository_h"
      AC_CHECK_FUNC(g_irepository_get_default, [gi_lib_ok=yes])

      if test xyesyes = "x$gi_header_ok$gi_lib_ok" ; then
        AC_CHECK_HEADERS(girffi.h,,,[
#include <girepository.h>
                         ])
        AC_CHECK_FUNCS(g_callable_info_create_closure g_constant_info_free_value
                       g_object_info_find_signal g_interface_info_find_signal
                       g_value_get_schar g_value_set_schar
                       g_property_info_get_getter)
        AC_CHECK_DECLS([GI_TYPE_TAG_UNICHAR],
                       [], [], [[#include <girepository.h>]])
        AC_DEFINE(HAVE_GI, 1, [Define to major version of GI if available and to be built])
        PIKE_FEATURE_OK(GI, 1.0)
      else
          GI_CFLAGS=""
          GI_LIBS=""
          CPPFLAGS="$OLDCPPFLAGS"
          LIBS="$OLDLIBS"
      fi
    ;;
  esac
fi

AC_OUTPUT(Makefile,echo FOO >stamp-h )
