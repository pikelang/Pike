/* Added in gobject-introspection 1.30.1 to fix memory leak */
#define g_constant_info_free_value(info, value) do{}while(0)
#endif

#ifndef HAVE_G_INTERFACE_INFO_FIND_SIGNAL
/* Added in gobject-introspection 1.34 */
static GISignalInfo *g_interface_info_find_signal (GIInterfaceInfo *info,
                                                   const gchar  *name)
{
  gint i, n_signals = g_interface_info_get_n_signals (info);
  for (i = 0; i < n_signals; i++) {
    GISignalInfo *siginfo = g_interface_info_get_signal (info, i);
    if (g_strcmp0 (g_base_info_get_name (siginfo), name) == 0)
      return siginfo;
    g_base_info_unref ((GIBaseInfo*)siginfo);
  }
  return NULL;
}
#endif

#ifndef HAVE_G_OBJECT_INFO_FIND_SIGNAL
/* Added in gobject-introspection 1.39 */
static GISignalInfo *g_object_info_find_signal (GIObjectInfo *info,
                                                const gchar  *name)
{
  gint i, n_signals = g_object_info_get_n_signals (info);
  for (i = 0; i < n_signals; i++) {
    GISignalInfo *siginfo = g_object_info_get_signal (info, i);
    if (g_strcmp0 (g_base_info_get_name (siginfo), name) == 0)
      return siginfo;
    g_base_info_unref ((GIBaseInfo*)siginfo);
  }
  return NULL;
}
#endif

#endif
